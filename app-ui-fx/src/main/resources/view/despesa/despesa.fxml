<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<?import com.br.appuifx.view.shared.CbDefault?>
<?import com.br.appuifx.view.shared.AutoComplete?>
<TitledPane collapsible="false" expanded="true" prefHeight="Infinity" prefWidth="Infinity" text="Despesa"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.br.appuifx.controller.despesa.DespesaController">
    <BorderPane>
        <left>
            <VBox minWidth="500.0" maxWidth="500.0" spacing="10.0">
                <Label text="Tipo Despesa: " />
                <CbDefault fx:id="cbTipoDespesa" maxWidth="Infinity" visibleRowCount="25" />
                <Label text="Fornecedor: " />
                <AutoComplete fx:id="inputFornec" maxWidth="Infinity" promptText="fornecedor" />
                <Label text="Data: " />
                <TextField fx:id="inputData" maxWidth="Infinity" promptText="dd/MM/yyyy" />
                <Label text="Forma Pagamento: " />
                <CbDefault fx:id="cbFormaPgto" maxWidth="Infinity" visibleRowCount="25" />
                <Label text="Valor: " />
                <TextField fx:id="inputValor" maxWidth="Infinity" promptText="0,00" />
                <Label text="Observação: " />
                <TextArea fx:id="inputObs" prefRowCount="3" promptText="obserevação" maxWidth="Infinity"/>
                <StackPane>
                    <Button minHeight="40" minWidth="100" mnemonicParsing="false" onAction="#salvar" text="Salvar">
                        <graphic>
                            <FontIcon iconLiteral="fas-save" iconSize="18" styleClass="bt-default"/>
                        </graphic>
                    </Button>
                </StackPane>
                <StackPane>
                    <Text fx:id="total" styleClass="label-status"/>
                    <padding>
                        <Insets bottom="10" left="10" right="10" top="60" />
                    </padding>
                </StackPane>
                <StackPane>
                    <Text fx:id="qtd" styleClass="label-status"/>
                    <padding>
                        <Insets bottom="10" left="10" right="10" top="10" />
                    </padding>
                </StackPane>
                <padding>
                    <Insets bottom="10" left="10" right="10" top="50" />
                </padding>
            </VBox>
        </left>
        <center>
            <BorderPane prefHeight="400.0" prefWidth="600.0">
                <top>
                    <HBox alignment="CENTER" spacing="10.0">
                        <Label text="Tipo: " />
                        <CbDefault fx:id="cbTipoDespesaFilter" prefWidth="250.0" visibleRowCount="25" />
                        <Label text="Fornecedor: " />
                        <AutoComplete fx:id="inputFornecFilter" prefWidth="400.0" promptText="fornecedor" />
                        <Label text="Período: " />
                        <TextField fx:id="inputInicio" maxWidth="120.0" promptText="dd/MM/yyyy" />
                        <TextField fx:id="inputTermino" maxWidth="120.0" promptText="dd/MM/yyyy" />
                        <Button minWidth="50" onAction="#loadoDespesas">
                            <graphic>
                                <FontIcon iconLiteral="fas-search" styleClass="bt-default"/>
                            </graphic>
                        </Button>
                        <Button minWidth="50" onAction="#resetFilter">
                            <graphic>
                                <FontIcon iconLiteral="fas-search-minus" styleClass="bt-default"/>
                            </graphic>
                        </Button>
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                    </HBox>
                </top>
                <center>
                    <StackPane>
                        <TableView fx:id="tableDespesa" prefWidth="600">
                            <columns>
                                <TableColumn fx:id="colTipo" prefWidth="200" text="Tipo Despesa" />
                                <TableColumn fx:id="colFonecedor" prefWidth="350" text="Fornecedor" />
                                <TableColumn fx:id="colData" prefWidth="110" text="Data" style="-fx-font-style: italic; -fx-font-weight: bold;" />
                                <TableColumn fx:id="colFormaPgto" prefWidth="250" text="Forma Pgto" />
                                <TableColumn fx:id="colValor" prefWidth="100" text="Valor" />
                                <TableColumn fx:id="colObs" minWidth="200" text="Observação" />
                                <TableColumn fx:id="colEdit" minWidth="20" text="Editar"/>
                                <TableColumn fx:id="colDel" minWidth="20" text="Excluir"/>
                            </columns>
                            <contextMenu>
                                <ContextMenu>
                                    <items>
                                        <MenuItem text="Editar" onAction="#editar">
                                            <graphic>
                                                <FontIcon iconLiteral="far-edit" />
                                            </graphic>
                                        </MenuItem>
                                        <MenuItem text="Excluir" onAction="#excluir">
                                            <graphic>
                                                <FontIcon iconLiteral="far-trash-alt" />
                                            </graphic>
                                        </MenuItem>
                                    </items>
                                </ContextMenu>
                            </contextMenu>
                        </TableView>
                        <fx:include fx:id="loading" source="/view/loading.fxml" />
                    </StackPane>
                </center>
            </BorderPane>
        </center>
    </BorderPane>
</TitledPane>
