<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<BorderPane fx:id="rootPane" prefHeight="1080.0" prefWidth="1920.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.br.appuifx.controller.MainController">
    <top>
        <MenuBar>
            <menus>
                <Menu text="Aplicação">
                    <graphic>
                        <FontIcon iconLiteral="fas-home"/>
                    </graphic>
                    <items>
                        <MenuItem text="DashBoard" >
                            <graphic>
                                <FontIcon iconLiteral="fab-deezer"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem text="Settings">
                            <graphic>
                                <FontIcon iconLiteral="fas-cog"/>
                            </graphic>
                        </MenuItem>
                        <SeparatorMenuItem />
                        <MenuItem text="Sair" onAction="#sair">
                            <graphic>
                                <FontIcon iconLiteral="fas-door-open"/>
                            </graphic>
                        </MenuItem>
                    </items>
                </Menu>

                <Menu text="_Financeiro">
                    <graphic>
                        <FontIcon iconLiteral="fas-dollar-sign"/>
                    </graphic>
                    <items>
                        <MenuItem text="_Despesa" onAction="#openDespesa">
                            <graphic>
                                <FontIcon iconLiteral="fas-money-bill-wave-alt"/>
                            </graphic>
                        </MenuItem>
                        <MenuItem text="Conta">
                            <graphic>
                                <FontIcon iconLiteral="fas-barcode"/>
                            </graphic>
                        </MenuItem>
                        <Menu text="Fornecedor">
                            <graphic>
                                <FontIcon iconLiteral="fas-box"/>
                            </graphic>

                            <items>
                                <MenuItem text="Pesssoa Fisíca" onAction="#openPF">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-dollar-sign"/>
                                    </graphic>
                                </MenuItem>
                                <MenuItem text="Pesssoa Juridica" onAction="#openPJ">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-building"/>
                                    </graphic>
                                </MenuItem>
                            </items>
                        </Menu>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

</BorderPane>
